# Notion Integration Token
# https://www.notion.so/my-integrations で作成
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxx

# Notion Database ID
# データベースページのURLから取得: https://www.notion.so/<DATABASE_ID>?v=...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Analytics 4 Property ID
# GA4 管理画面 → プロパティ設定 → プロパティID（数字のみ）
GA_PROPERTY_ID=000000000

# Google Service Account 認証情報
# 方法A: サービスアカウントキーのJSONファイルパス（ローカル用）
# GOOGLE_APPLICATION_CREDENTIALS=./credentials/ga-service-account.json
#
# 方法B: サービスアカウントキーのJSON文字列をBase64エンコード（GitHub Actions用）
# GOOGLE_CREDENTIALS_JSON=eyJ0eXBlIjoic2Vydi...
